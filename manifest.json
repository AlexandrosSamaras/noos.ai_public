{
  "manifest_version": 3,
  "name": "Noos.AI",
  "version": "2.5.1",
  "description": "Get 10 FREE daily AI actions! Summarize, explain, search, translate, and analyze any text. Your all-in-one AI browser copilot.",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "unlimitedStorage",
    "contextMenus",
    "clipboardWrite"
  ],
  "host_permissions": [
    "https://sentiment-analyzer-service-872183226779.us-central1.run.app/",
    "https://api.notion.com/"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "css": [
        "content.css"
      ],
      "js": [
        "content_utils.js",
        "content.js"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "NoosAI Actions & Settings",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "options_page": "options.html"
}